@model Academico.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="login-shell">
    <div class="row g-0 login-panel">
        <div class="col-lg-5 login-aside p-5 d-flex flex-column justify-content-between">
            <div>
                <p class="text-uppercase small fw-semibold mb-3">Entrada administrativa</p>
                <h1 class="h2 fw-bold">Acesse a central da instituicao.</h1>
                <p class="mt-3 mb-0">Use sua credencial para manter cadastros, professores e disciplinas sob controle.</p>
            </div>
        </div>
        <div class="col-lg-7 p-4 p-md-5">
            <span class="panel-label">Login seguro</span>
            <h2 class="section-title">Identifique-se para continuar</h2>
            <form asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" autocomplete="username" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Senha"></label>
                    <input asp-for="Senha" class="form-control" autocomplete="current-password" />
                    <span asp-validation-for="Senha" class="text-danger"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="LembrarMe" class="form-check-input" />
                    <label asp-for="LembrarMe" class="form-check-label">Manter conectado</label>
                </div>

                <button type="submit" class="btn btn-primary w-100">Entrar</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
