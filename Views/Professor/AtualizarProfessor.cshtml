@model Professor

@{
    ViewData["Title"] = "Atualizar professor";
}

<div class="form-panel">
    <span class="panel-label">Ajuste docente</span>
    <h1 class="section-title">Atualizar professor</h1>
    <p class="form-intro">Revise area, SIAPE e dados pessoais antes de gravar a nova versao do cadastro.</p>
    <form method="post" asp-controller="Professor" asp-action="AtualizarProfessor">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label asp-for="Nome"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Cpf">CPF</label>
            <input asp-for="Cpf" class="form-control" placeholder="000.000.000-00" />
            <span asp-validation-for="Cpf" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Siape">SIAPE</label>
            <input asp-for="Siape" class="form-control" />
            <span asp-validation-for="Siape" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="DataNascimento">Data de nascimento</label>
            <input asp-for="DataNascimento" class="form-control" type="date" />
            <span asp-validation-for="DataNascimento" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Area"></label>
            <select asp-for="Area" class="form-control">
                <option value="">Selecione a area</option>
                <option value="Computacao">Computacao</option>
                <option value="Agronomia">Agronomia</option>
                <option value="Matematica">Matematica</option>
                <option value="Gestao Academica">Gestao Academica</option>
            </select>
            <span asp-validation-for="Area" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary">Salvar alteracoes</button>
            <a class="btn btn-outline-secondary" asp-controller="Professor" asp-action="Index">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
