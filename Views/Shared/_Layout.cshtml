<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Sistema Academico")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">GA</span>
                    Gestao Academica
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu" aria-controls="mainMenu" aria-expanded="false" aria-label="Abrir menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainMenu">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Painel</a></li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Aluno" asp-action="Index">Alunos</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Professor" asp-action="Index">Professores</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Disciplina" asp-action="Index">Disciplinas</a></li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="navbar-text small">Ola, @User.Identity.Name</span>
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                <button type="submit" class="btn btn-outline-light btn-sm">Sair</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-light btn-sm" asp-controller="Auth" asp-action="Login">Entrar</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="container app-main">
        @if (TempData["Mensagem"] != null)
        {
            <div class="alert alert-@TempData["Tipo"] alert-dismissible fade show" role="alert">
                @TempData["Mensagem"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="app-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>Gestao Academica Integrada</span>
            <span>Controle de cadastros, acesso e registros institucionais</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
